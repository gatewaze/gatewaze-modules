    "@gatewaze/shared": "*"
  },
  "dependencies": {
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "vitest": "^4.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0"
