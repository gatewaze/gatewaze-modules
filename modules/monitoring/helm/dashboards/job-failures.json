{
  "title": "Gatewaze — Job Failures",
  "uid": "gatewaze-job-failures",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["gatewaze"],
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Terminal failures (last 24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        { "expr": "sum(increase(gatewaze_job_terminal_failures_total[24h]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "title": "Terminal failure rate (per second)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum by (queue, name) (rate(gatewaze_job_terminal_failures_total[5m]))",
          "legendFormat": "{{queue}} / {{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 3,
      "title": "Failure share by queue (last 1h)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum by (queue) (increase(gatewaze_job_terminal_failures_total[1h]))",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Failure share by job name (last 1h)",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum by (name) (increase(gatewaze_job_terminal_failures_total[1h]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Failed-status job duration distribution",
      "type": "heatmap",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum by (le) (rate(gatewaze_job_duration_seconds_bucket{status=\"failed\"}[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "options": { "calculate": false, "yAxis": { "unit": "s" } }
    }
  ]
}
